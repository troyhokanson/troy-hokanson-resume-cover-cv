# config.example.env — Template for local .env setup
# =====================================================
# Copy this file to .env and fill in your real values.
# The .env file is gitignored and will never be committed.
#
# These values are injected into resume/cover letter headers at build time.
# If a variable is missing, the build falls back to a safe placeholder.

TROY_PHONE=612.555.0000
TROY_EMAIL=yourname@example.com
TROY_LOCATION=City, ST
TROY_LINKEDIN=linkedin.com/in/yourprofile
TROY_PORTFOLIO=https://yourname.github.io/portfolio
TROY_NAME=Troy J. Hokanson
